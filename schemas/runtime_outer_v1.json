{
  "$defs": {
    "RuntimeContractDiagnostics": {
      "additionalProperties": false,
      "description": "Minimal runtime diagnostics for debugging orchestration issues.",
      "properties": {
        "ranking_explanation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Ranking Explanation"
        },
        "support_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Support Reason"
        },
        "token_count": {
          "title": "Token Count",
          "type": "integer"
        },
        "selection_strategy": {
          "title": "Selection Strategy",
          "type": "string"
        }
      },
      "required": [
        "ranking_explanation",
        "support_reason",
        "token_count",
        "selection_strategy"
      ],
      "title": "RuntimeContractDiagnostics",
      "type": "object"
    },
    "RuntimeContractIntent": {
      "additionalProperties": false,
      "description": "Stable runtime-facing query intent summary.",
      "properties": {
        "query_intent": {
          "title": "Query Intent",
          "type": "string"
        },
        "task_intent": {
          "title": "Task Intent",
          "type": "string"
        },
        "concept_families": {
          "items": {
            "type": "string"
          },
          "title": "Concept Families",
          "type": "array"
        }
      },
      "required": [
        "query_intent",
        "task_intent",
        "concept_families"
      ],
      "title": "RuntimeContractIntent",
      "type": "object"
    },
    "RuntimeContractSource": {
      "additionalProperties": false,
      "description": "Runtime-facing provenance for a returned knowledge bundle.",
      "properties": {
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Name"
        },
        "type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Type"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Url"
        },
        "canonical_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Canonical Url"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "document_title": {
          "title": "Document Title",
          "type": "string"
        },
        "section_title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Section Title"
        },
        "heading_path": {
          "items": {
            "type": "string"
          },
          "title": "Heading Path",
          "type": "array"
        }
      },
      "required": [
        "name",
        "type",
        "url",
        "canonical_url",
        "path",
        "document_title",
        "section_title",
        "heading_path"
      ],
      "title": "RuntimeContractSource",
      "type": "object"
    },
    "SharedRuntimeContractContent": {
      "additionalProperties": true,
      "description": "Tool-specific runtime payload carried inside the shared outer envelope.\n\nThe shared cross-tool contract intentionally does not constrain the inner\nshape beyond \"must be an object\". `agentic_docs` layers its richer content\nmodel on top of this shared shell.",
      "properties": {},
      "title": "SharedRuntimeContractContent",
      "type": "object"
    },
    "SharedRuntimeContractResult": {
      "additionalProperties": false,
      "description": "Shared cross-tool runtime result wrapper.\n\nThis preserves the common provenance and diagnostics shape while allowing\neach tool to define its own `content` payload.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "rank": {
          "title": "Rank",
          "type": "integer"
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/RuntimeContractSource"
        },
        "content": {
          "$ref": "#/$defs/SharedRuntimeContractContent"
        },
        "diagnostics": {
          "$ref": "#/$defs/RuntimeContractDiagnostics"
        }
      },
      "required": [
        "id",
        "type",
        "rank",
        "confidence",
        "source",
        "content",
        "diagnostics"
      ],
      "title": "SharedRuntimeContractResult",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Canonical shared outer envelope for the Moodle agentic tool family.",
  "properties": {
    "tool": {
      "title": "Tool",
      "type": "string"
    },
    "version": {
      "title": "Version",
      "type": "string"
    },
    "query": {
      "title": "Query",
      "type": "string"
    },
    "normalized_query": {
      "title": "Normalized Query",
      "type": "string"
    },
    "intent": {
      "$ref": "#/$defs/RuntimeContractIntent"
    },
    "results": {
      "items": {
        "$ref": "#/$defs/SharedRuntimeContractResult"
      },
      "title": "Results",
      "type": "array"
    }
  },
  "required": [
    "tool",
    "version",
    "query",
    "normalized_query",
    "intent",
    "results"
  ],
  "title": "SharedRuntimeContractEnvelope",
  "type": "object"
}
